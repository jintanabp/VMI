generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SalesRep {
  id     String  @id @default(cuid())
  email  String  @unique
  name   String
  stores Store[]
}

model Store {
  id              String               @id @default(cuid())
  code            String               @unique
  name            String
  salesRepId      String?
  salesRep        SalesRep?            @relation(fields: [salesRepId], references: [id])
  stockItems      StockItem[]
  orders          Order[]
  groupThresholds StoreGroupThreshold[]
  skuBlocks       StoreSkuBlock[]
}

model Sku {
  id         String      @id @default(cuid())
  code       String      @unique
  name       String
  createdAt  DateTime    @default(now())
  stockItems StockItem[]
  promoTiers PromoTier[]
  orderItems OrderItem[]
  skuBlocks  StoreSkuBlock[]
}

model StockItem {
  storeId  String
  skuId    String
  stock    Float
  avgSales Float
  minDays  Int    @default(7)
  maxDays  Int    @default(15)
  store    Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sku      Sku    @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@id([storeId, skuId])
}

model PromoTier {
  id        String @id @default(cuid())
  skuId     String
  minQty    Int
  discount  String
  sortOrder Int
  sku       Sku    @relation(fields: [skuId], references: [id], onDelete: Cascade)
}

model Order {
  id           String      @id @default(cuid())
  storeId      String
  status       String      @default("pending_approval")
  rejectReason String?
  createdAt    DateTime    @default(now())
  approvedAt   DateTime?
  store        Store       @relation(fields: [storeId], references: [id])
  items        OrderItem[]
}

model OrderItem {
  id           String @id @default(cuid())
  orderId      String
  skuId        String
  suggestedQty Int
  finalQty     Int
  cvdEstimate  Float?
  order        Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sku          Sku    @relation(fields: [skuId], references: [id])
}

model AllowedSalesCode {
  code      String   @id
  createdAt DateTime @default(now())
}

/// ผู้ดูแลระบบ — bootstrap จาก ADMIN_EMAILS / APP_ADMINS แล้วเพิ่มผ่าน UI ได้
model Admin {
  email   String   @id
  fromEnv Boolean  @default(false)
  addedBy String   @default("")
  addedAt DateTime @default(now())
}

/// บัญชีร้านค้า — login ด้วยอีเมล + รหัสผ่านที่ตั้งเอง (แอดมินอนุมัติสิทธิ)
model StoreAccount {
  id               String    @id @default(cuid())
  email            String    @unique
  vdaCode          String
  status           String    @default("pending") // pending | approved | rejected
  passwordHash     String?
  mustSetPassword  Boolean   @default(true)
  canManageMinMax  Boolean   @default(false)
  resetRequestedAt DateTime?
  approvedBy       String    @default("")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([vdaCode])
}

/// ค่า min/max ระดับ product group (Section) ต่อร้าน — ใช้เป็น default ก่อน override รายตัว
model StoreGroupThreshold {
  id        String   @id @default(cuid())
  storeId   String
  section   String
  minDays   Int      @default(7)
  maxDays   Int      @default(15)
  updatedBy String   @default("")
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, section])
}

/// รายการ "หยุดสั่ง / เอาออกจากคลัง" ต่อร้านต่อ SKU — ระงับ suggest และแจ้งเซลล์
model StoreSkuBlock {
  id             String    @id @default(cuid())
  storeId        String
  skuId          String
  reason         String
  effectiveFrom  DateTime  @default(now()) // เริ่มหยุดสั่งตั้งแต่เมื่อไหร่ (อาจเป็นอนาคต)
  createdBy      String    @default("")
  createdAt      DateTime  @default(now())
  acknowledgedAt DateTime?                 // เซลล์กดรับทราบเมื่อไหร่ (null = ยังไม่อ่าน)
  store          Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sku            Sku       @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@unique([storeId, skuId])
  @@index([storeId])
}

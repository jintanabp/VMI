# =============================================================================
# VMI — local dev defaults (copy to .env and fill secrets)
# Production Docker overrides DATABASE_URL via docker-compose.yml
# =============================================================================

# Database — dev: prisma/dev.db | Docker: file:/app/data/vmi.db
DATABASE_URL="file:./dev.db"

# Session signing — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=your-random-secret-here

# Azure AD — sales login (แยกจาก ONELAKE service principal)
NEXT_PUBLIC_AZURE_AD_CLIENT_ID=your-client-id-here
NEXT_PUBLIC_AZURE_AD_TENANT_ID=your-tenant-id-here

# Redirect URI — must match Azure App Registration exactly
# Dev:  http://localhost:3000/auth/callback
# Prod: https://<your-domain>/auth/callback
# NEXT_PUBLIC_AZURE_REDIRECT_URI=http://localhost:3000/auth/callback

# Optional confidential client (if Azure app is Web platform)
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_USE_CLIENT_SECRET=true

# Admin emails (comma or semicolon) — bootstrap on startup
ADMIN_EMAILS=your-email@company.com
# APP_ADMINS=your-email@company.com

# Data source: dummy | fabric
DATA_SOURCE=dummy

# --- Fabric OneLake master data (customer + salesman) ---
# Auth priority (same as ocr-po-matching):
#   1) ONELAKE_TENANT_ID + ONELAKE_CLIENT_ID + ONELAKE_CLIENT_SECRET
#   2) AZURE_TENANT_ID + AZURE_CLIENT_ID + AZURE_CLIENT_SECRET
#   3) az login (DefaultAzureCredential)
#   4) Admin manual refresh → interactive browser login
#
# ONELAKE_TENANT_ID=
# ONELAKE_CLIENT_ID=
# ONELAKE_CLIENT_SECRET=
# ONELAKE_WORKSPACE_ID=
# ONELAKE_LAKEHOUSE_ID=
# ONELAKE_SCAN_DIR=Files/exports/
# USE_FABRIC_MASTERS=true

# --- Fabric stock workspace (VMI-only, separate from masters) ---
# USE_FABRIC_STOCK=true
# STOCK_ONELAKE_TENANT_ID=
# STOCK_ONELAKE_CLIENT_ID=
# STOCK_ONELAKE_CLIENT_SECRET=
# STOCK_ONELAKE_WORKSPACE_ID=
# STOCK_ONELAKE_LAKEHOUSE_ID=
# STOCK_ONELAKE_SCAN_DIR=Files/exports/
# STOCK_COVER_ONELAKE_PATH=Files/exports/stock_cover_day.csv
# ONELAKE_WAREHOUSE_ID=

# --- VDA → salesman (vda{N}_aos_bill) ---
# VDA_AOS_WORKSPACE_ID=
# VDA_AOS_LAKEHOUSE_ID=
# VDA_AOS_SCAN_DIR=Files/exports/
# VDA_SALESMAN_MAP=vda1:S001,vda2:S002
# map VDA → customercode สำหรับกรองยอดขายรายวันรายร้าน (fallback เมื่อไม่มี vda_aos_bill CSV)
# หลายรหัสต่อ VDA คั่นด้วย | เช่น vda1:3231847|3231848
# VDA_CUSTOMER_MAP=vda1:3231847,vda2:5042814

# --- SKU + C4 promo ---
# SKU_ONELAKE_PATH=Files/exports/item_barcode_map_v2.csv
# CFT_ONELAKE_PATH=Files/exports/cft_promotion_credit.csv
# C4_DEFAULT_DIVISION=S
# C4_DEFAULT_CUSGROUP=99
# C4_DEFAULT_REGION=COUNTRY
# C4_VDA_DIVISION_MAP=vda1:S,vda2:E,vda3:B,vda4:W,vda5:S

# Min row guards — reject refresh if file too small
# CUSTOMER_MIN_ROWS=20000
# SALESMAN_MIN_ROWS=1000
# STOCK_COVER_MIN_ROWS=100
# SKU_MIN_ROWS=50000
# CFT_MIN_ROWS=1000

# Stock page filter
# STOCK_FILTER_MODE=from_db

# --- Daily Fabric auto-sync (Asia/Bangkok) ---
# Enabled automatically when NODE_ENV=production, or set explicitly:
# MASTER_REFRESH_ENABLED=true
# MASTER_REFRESH_HOUR=3
# MASTER_REFRESH_MINUTE=30

# Alert when scheduled sync fails after retries (same as ocr-po-matching)
ALERT_EMAIL=jintana.b@sahapat.co.th
# SENDER_EMAIL=   # optional — Microsoft Graph sender mailbox (Mail.Send)

# --- New-product highlight ---
# SKU ถือว่า "ใหม่" ถ้าเพิ่งเข้าข้อมูล Fabric ภายในกี่วันล่าสุด (default 30)
# NEW_PRODUCT_DAYS=30

# --- Docker production only ---
# BACKUP_DIR=/app/backups
# FABRIC_CACHE_DIR=/app/data/cache

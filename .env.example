# Database (path สัมพันธ์กับ prisma/schema.prisma → ไฟล์จริงอยู่ที่ prisma/dev.db)

DATABASE_URL="file:./dev.db"



# Session signing (สุ่ม string ยาวๆ)

NEXTAUTH_SECRET=your-random-secret-here



# Azure AD — App registrations (MSAL sales login)

NEXT_PUBLIC_AZURE_AD_CLIENT_ID=your-client-id-here

NEXT_PUBLIC_AZURE_AD_TENANT_ID=your-tenant-id-here



# Redirect URI (ต้องตรงกับ Azure SPA — default: http://localhost:3000/auth/callback)

# NEXT_PUBLIC_AZURE_REDIRECT_URI=http://localhost:3000/auth/callback



# Admin emails (comma or semicolon) — ทุกคนในรายการได้ role admin
# ชื่อตัวแปรใช้ ADMIN_EMAILS หรือ APP_ADMINS (เหมือน ocr-po-matching) ก็ได้
ADMIN_EMAILS=your-email@company.com,another-admin@company.com
# APP_ADMINS=your-email@company.com



# Data source: dummy | fabric

DATA_SOURCE=dummy



# --- Fabric OneLake master data (customer + salesman) ---
# แยกจาก MSAL login — ดึง CSV จาก lakehouse
# Auth แบบเดียวกับ ocr-po-matching (ลำดับความสำคัญ):
#   1) ONELAKE_TENANT_ID + ONELAKE_CLIENT_ID + ONELAKE_CLIENT_SECRET
#   2) AZURE_TENANT_ID + AZURE_CLIENT_ID + AZURE_CLIENT_SECRET (ชุดเดียวกับ ocr-po)
#   3) az login (DefaultAzureCredential) — sync รายวัน / npm run sync:masters
#   4) Admin กดดึงข้อมูล → browser login (InteractiveBrowserCredential)
#
# ONELAKE_TENANT_ID=
# ONELAKE_CLIENT_ID=
# ONELAKE_CLIENT_SECRET=
# หรือใช้ร่วมกับ ocr-po-matching:
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# --- Fabric: workspace ร้านค้า + พนักงาน (lakehouse) ---
# ใช้ชุดเดียวกับ ocr-po-matching
# ONELAKE_WORKSPACE_ID=
# ONELAKE_LAKEHOUSE_ID=
# ONELAKE_SCAN_DIR=Files/exports/
# USE_FABRIC_MASTERS=true

# --- Fabric: workspace stock (คนละ workspace กับด้านบน) ---
# mirrored warehouse stock_cover_day
# USE_FABRIC_STOCK=true
# STOCK_ONELAKE_TENANT_ID=
# STOCK_ONELAKE_CLIENT_ID=
# STOCK_ONELAKE_CLIENT_SECRET=
# STOCK_ONELAKE_WORKSPACE_ID=650809d9-f661-4d2b-9e4b-0d50c00f17e1
# ONELAKE_WAREHOUSE_ID=e8cdc3ec-e0cd-4b9f-8836-563591c12799
# STOCK_ONELAKE_LAKEHOUSE_ID=   # Lakehouse รับ CSV export (Mirrored Warehouse ไม่มี Files/)
# STOCK_ONELAKE_SCAN_DIR=Files/exports/
# STOCK_COVER_ONELAKE_PATH=Files/exports/stock_cover_day.csv
# ถ้ายังไม่มี CSV export — ตาราง mirror อยู่ที่ Tables/dbo/stock_cover_day/ (Delta)
# รัน npm run probe:stock-onelake เพื่อเช็คสิทธิ์ + path
# ทางเลือก: สร้าง Fabric pipeline export ตาราง → CSV รายวัน (แนะนำ) หรือ SQL endpoint (Phase 2)
# STOCK_COVER_CSV=data/cache/stock_cover_day.csv

# Local cache paths (default: data/cache/*.csv)

# CUSTOMER_MASTER_CSV=

# SALESMAN_CSV=

# --- SKU price master (item_barcode_map_v2) ---
# SKU_MASTER_CSV=data/cache/item_barcode_map_v2.csv
# SKU_ONELAKE_PATH=Files/exports/item_barcode_map_v2.csv
# SKU_MIN_ROWS=50000

# --- C4 Promotion (cft_promotion_credit) ---
# PROMOTION_CSV=data/cache/cft_promotion_credit.csv
# CFT_ONELAKE_PATH=Files/exports/cft_promotion_credit.csv
# CFT_MIN_ROWS=1000
# C4_DEFAULT_DIVISION=S
# C4_DEFAULT_CUSGROUP=99
# C4_DEFAULT_REGION=COUNTRY
# C4_VDA_DIVISION_MAP=vda1:S,vda2:E,vda3:B

# Min row guards — ปฏิเสธ refresh ถ้าไฟล์เล็กเกินไป

# CUSTOMER_MIN_ROWS=20000

# SALESMAN_MIN_ROWS=1000



# Optional fixed OneLake paths (ถ้าไม่ตั้ง จะ auto-discover ใน ONELAKE_SCAN_DIR)

# CUSTOMER_ONELAKE_PATH=Files/exports/dim_customer.csv

# SALESMAN_ONELAKE_PATH=Files/exports/cross_salesman_reference_email.csv

# STOCK_COVER_MIN_ROWS=100

# Filter หน้า stock — from_db ดึงอัตโนมัติจาก stock_cover_day.csv
# STOCK_FILTER_MODE=from_db
# STOCK_FILTER_MODE=vda        # กรองเฉพาะ prefix STOCK_VDA_PREFIX
# STOCK_VDA_PREFIX=vda
# STOCK_FROM_DB_OPTIONS=       # ว่าง = ทุก from_db ในตาราง (ไม่ต้อง hardcode)
# STOCK_FROM_DB_DEFAULT=       # ว่าง = ตัวแรกตามตัวอักษร
# STOCK_COVER_STORE_COLUMN=customercode

# --- Daily auto-sync (แบบ ocr-po-matching) ---
# เปิดเมื่อรัน production server ค้าง 24/7 (npm run start)
# MASTER_REFRESH_ENABLED=true
# MASTER_REFRESH_HOUR=3
# MASTER_REFRESH_MINUTE=30
# เวลา Asia/Bangkok — default 03:30 (หลัง Fabric export ~02:50)

